nts) }</script><script id="__NEXT_DATA__" type="application/json" crossorigin="anonymous">{"props":{"locale":"fr-FR","url":"https://fashionunited.fr/actualite/retail/en-image-le-nouveau-flagship-de-nike-sur-les-champs-elysees/2020073024415","pageProps":{"apolloState":{"LocalNewsUser:577":{"__typename":"LocalNewsUser","email":"sharon@fashionunited.com","id":577,"name":"Sharon Camara"},"Tag:{\"slug\":\"nike\"}":{"__typename":"Tag","title":"Nike","slug":"nike"},"LocalNewsCategory:9":{"__typename":"LocalNewsCategory","id":9,"title":"Retail","path":"actualite/retail"},"LocalNewsArticle:24415":{"__typename":"LocalNewsArticle","id":24415,"title":"En image : le nouveau flagship de Nike sur les Champs Élysées","description":"Le nouveau flagship de Nike s’étend sur quatre étages et sur 2400 mètres carrés. Après ceux de New York et Shanghai, le nouvel espace situé sur les Ch","body":"\n\u003cp\u003eLe nouveau flagship de Nike s’étend sur quatre étages et sur 2400 mètres\ncarrés. Après ceux de New York et Shanghai, le nouvel espace situé sur les\nChamps Élysées offrira une expérience immersive et digitale. Dans un espace\nentièrement dédié au sport, les consommateurs auront accès au plus large\nassortiment de sneakers en Europe et à des exclusivités pour les membres\nNike.\u003c/p\u003e\n\n\n\n\u003cp\u003e« Nike Paris représente notre volonté de créer des lieux inspirants qui\nen même temps offrent les produits les plus innovants à tous les athlètes\n», précise dans un communiqué, Heidi O’Neill, president of consumer and\nmarketplace de Nike. « En entrant dans la House of Innovation, les\nconsommateurs feront l’expérience de notre concept retail le plus immersif\nd’une manière entièrement personnalisée, les reliant au monde de Nike grâce\nà leur relation avec notre marque, à travers notre portfolio digital. »\u003c/p\u003e\n\n\n\n\n\u003cdiv class=\"image-container\"\u003e\u003cprogressive-img placeholder=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-2.jpg\" src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-2.jpg\" srcset=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=582/https://static.fashionunited.com/202007/Nike-Showroom-2.jpg 582w, https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-2.jpg 1164w\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" load-strategy=\"on-visible\"\u003e\u003c/progressive-img\u003e\u003cnoscript\u003e\u003cimg src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-2.jpg\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\"/\u003e\u003c/noscript\u003e\u003c/div\u003e\n\u003ch2\u003e De nombreuses innovations\u003c/h2\u003e\n\n\u003cp\u003eParmi les nouveautés à trouver en magasin, l’installation  Mission\nControl, située à l’entrée du magasin. Elle connecte les acheteurs à la\ncommunauté sportive mondiale et locale, proposant des avantages exclusifs\npour les membres et affichant les dernières actions des Nike House of\nInnovation de New York et Shanghai.\u003c/p\u003e\n\n\n\u003cdiv class=\"image-container\"\u003e\u003cprogressive-img placeholder=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-3.jpg\" src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-3.jpg\" srcset=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=582/https://static.fashionunited.com/202007/Nike-Showroom-3.jpg 582w, https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-3.jpg 1164w\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" load-strategy=\"on-visible\"\u003e\u003c/progressive-img\u003e\u003cnoscript\u003e\u003cimg src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-3.jpg\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\"/\u003e\u003c/noscript\u003e\u003c/div\u003e\n\u003cp\u003eLe Bra Fit by Nike est un service innovant combinant personnalisation et\ncapacités digitales. Grâce à l\u0026#39;apprentissage automatique et exclusif de «\nShoe Fit by Nike » et aux algorithmes avancés de Nike, les acheteuses ont\nla possibilité en magasin de saisir leur tailles (ou d\u0026#39;effectuer une\névaluation auto-guidée) dans l\u0026#39;outil Bra Fit by Nike pour recevoir une\nrecommandation d\u0026#39;ajustement, pour tout soutien-gorge Nike. Cette évaluation\npermet également aux utilisatrices d\u0026#39;enregistrer ces informations dans un\nprofil de membre Nike pour une future référence d\u0026#39;achat.\u003c/p\u003e\n\n\n\u003cdiv class=\"image-container\"\u003e\u003cprogressive-img placeholder=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-4.jpg\" src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-4.jpg\" srcset=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=582/https://static.fashionunited.com/202007/Nike-Showroom-4.jpg 582w, https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-4.jpg 1164w\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" load-strategy=\"on-visible\"\u003e\u003c/progressive-img\u003e\u003cnoscript\u003e\u003cimg src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-4.jpg\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\"/\u003e\u003c/noscript\u003e\u003c/div\u003e\n\u003cp\u003eNike Paris met en avant ses capacités numériques à travers\nl’accélération digitale. Il y a notamment une suite complète de services\nNike App disponibles en magasin (BuyOnline. Reserve in Store, Nike Scan to\nLearn, Nike Scan to Try, Nike Shop the Look).\u003c/p\u003e\n\u003cdiv class=\"image-container\"\u003e\u003cprogressive-img placeholder=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-5.jpg\" src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-5.jpg\" srcset=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=582/https://static.fashionunited.com/202007/Nike-Showroom-5.jpg 582w, https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-5.jpg 1164w\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" load-strategy=\"on-visible\"\u003e\u003c/progressive-img\u003e\u003cnoscript\u003e\u003cimg src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-5.jpg\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\"/\u003e\u003c/noscript\u003e\u003c/div\u003e\n\u003cp\u003eLe Nike Paris, House of Innovation 002, ouvrira ses portes le 30\njuillet. Le magasin sera ouvert sept jours par semaine de 10 heures à 20\nheures.\u003c/p\u003e\n\n\u003cdiv class=\"image-container\"\u003e\u003cprogressive-img placeholder=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-6.jpg\" src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-6.jpg\" srcset=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=582/https://static.fashionunited.com/202007/Nike-Showroom-6.jpg 582w, https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-6.jpg 1164w\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" load-strategy=\"on-visible\"\u003e\u003c/progressive-img\u003e\u003cnoscript\u003e\u003cimg src=\"https://fashionunited.com/r/fit=cover,format=auto,gravity=center,quality=70,width=1164/https://static.fashionunited.com/202007/Nike-Showroom-6.jpg\" sizes=\"(min-width: 840px) 550px, (min-width: 582px) 582px, 100vw\" alt=\"En image : le nouveau flagship de Nike sur les Champs Élysées\" title=\"En image : le nouveau flagship de Nike sur les Champs Élysées\"/\u003e\u003c/noscript\u003e\u003c/div\u003e\n\u003cp\u003eCrédit : Nike\u003c/p\u003e\n","imageUrls({\"configurations\":[{\"format\":\"JPEG\",\"height\":630,\"resize\":\"FIT\",\"width\":1200},{\"height\":28,\"quality\":10,\"resize\":\"FILL_DOWN\",\"width\":42},{\"height\":240,\"resize\":\"FILL_DOWN\",\"width\":360},{\"height\":463,\"resize\":\"FILL_DOWN\",\"width\":694},{\"height\":480,\"resize\":\"FILL_DOWN\",\"width\":720},{\"height\":926,\"resize\":\"FILL_DOWN\",\"width\":1388}]})":["https://fashionunited.com/r/fit=contain,format=jpeg,gravity=center,height=630,quality=70,width=1200/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg","https://fashionunited.com/r/fit=cover,format=auto,gravity=center,height=28,quality=10,width=42/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg","https://fashionunited.com/r/fit=cover,format=auto,gravity=center,height=240,quality=70,width=360/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg","https://fashionunited.com/r/fit=cover,format=auto,gravity=center,height=463,quality=70,width=694/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg","https://fashionunited.com/r/fit=cover,format=auto,gravity=center,height=480,quality=70,width=720/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg","https://fashionunited.com/r/fit=cover,format=auto,gravity=center,height=926,quality=70,width=1388/https://static.fashionunited.com/202007/Nike-Showroom-1.jpg"],"imageCaption":null,"creator":{"__ref":"LocalNewsUser:577"},"tags({\"limit\":100})":[{"__ref":"Tag:{\"slug\":\"nike\"}"}],"insertedAt":"2020-07-30T06:01:08.000000Z","update